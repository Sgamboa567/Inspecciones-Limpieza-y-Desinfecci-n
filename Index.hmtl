<!DOCTYPE html>
<html>
  <head>
    <base target="_top">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <style>
      :root {
        --bg: #f7f7f7;
        --card: #ffffff;
        --text: #121212;
        --muted: #5f5f5f;
        --line: #d8d8d8;
        --black: #101010;
      }
      * { box-sizing: border-box; }
      body { margin: 0; font-family: 'Segoe UI', Roboto, sans-serif; color: var(--text); background: var(--bg); }
      .container { max-width: 880px; margin: 0 auto; padding: 14px; }
      .card { background: var(--card); border: 1px solid var(--line); border-radius: 12px; padding: 14px; }
      .brand { display: flex; align-items: center; gap: 10px; margin-bottom: 8px; }
      .brand img { max-width: 220px; width: 55vw; height: auto; object-fit: contain; }
      h1 { margin: 0; font-size: 1.25rem; }
      .small { color: var(--muted); font-size: .85rem; margin: 6px 0 0; }
      .grid { display: grid; gap: 12px; margin-top: 12px; }
      .field { margin-bottom: 12px; }
      label { display:block; font-weight: 600; margin-bottom: 6px; font-size: .92rem; }
      input, select, textarea { width:100%; padding:10px; border:1px solid var(--line); border-radius:8px; font: inherit; background: #fff; }
      textarea { min-height: 100px; resize: vertical; }
      .box, .checklist-item { border:1px solid var(--line); border-radius:10px; padding:10px; background:#fff; }
      .checklist-item { margin-bottom: 8px; }
      .chip { display:inline-flex; align-items:center; gap:6px; border:1px solid var(--line); border-radius:999px; padding:6px 10px; margin:4px 4px 0 0; font-size: .88rem; }
      .chip input { width: auto; }
      #signatureCanvas { width:100%; height:220px; border:2px dashed #bfbfbf; border-radius:10px; background:#fff; }
      .btn-row { display:flex; gap:8px; flex-wrap:wrap; margin-top:10px; }
      .btn { border:none; background:var(--black); color:#fff; padding:11px 14px; border-radius:9px; font-weight:600; cursor:pointer; }
      .btn-secondary { background:#5d5d5d; }
      .preview { margin-top: 8px; font-size: .84rem; color: var(--muted); }
      .status { display:none; margin-top:12px; padding:10px; border-radius:8px; font-size:.9rem; }
      .success { background:#eaf7ea; color:#1a6d1a; border:1px solid #a8d4a8; }
      .error { background:#fbecec; color:#a32c2c; border:1px solid #e3b0b0; }
      .hidden { display: none; }
      @media (min-width: 760px){ .grid { grid-template-columns: repeat(2, minmax(0,1fr)); } }
    </style>
  </head>
  <body>
    <main class="container">
      <section class="card">
        <div class="brand">
          <img src="<?= data.logoUrl ?>" alt="Logo OROEXPRESS" onerror="this.style.display='none'">
        </div>
        <h1>Inspección de Limpieza y Desinfección</h1>
        <p class="small">Completa el formulario y guarda el registro con evidencia y firma.</p>

        <div class="grid">
          <div class="field">
            <label>Fecha de inspección</label>
            <input type="date" id="fechaInspeccion">
          </div>

          <div class="field" id="joyeriaField">
            <label>Joyería</label>
            <select id="joyeria"></select>
            <div id="joyeriaFija" class="box hidden" style="margin-top:10px"></div>
          </div>

          <div class="field">
            <label>Correo de la joyería</label>
            <input type="email" id="correo" readonly>
          </div>

          <div class="field">
            <label>Responsable</label>
            <input type="text" id="responsable" placeholder="Nombre completo" list="responsablesList">
            <datalist id="responsablesList"></datalist>
          </div>
        </div>

        <div class="field">
          <label>ÁREA(S) limpiadas</label>
          <div id="areasContainer" class="box"></div>
        </div>

        <div class="field">
          <label>Checklist SST</label>
          <div id="checklistContainer"></div>
        </div>

        <div class="field">
          <label>Registro fotográfico</label>
          <input type="file" id="photos" accept="image/*" multiple capture="environment">
          <div class="preview" id="photoPreview"></div>
        </div>

        <div class="field">
          <label>Observaciones</label>
          <textarea id="observaciones" placeholder="Escribe observaciones, hallazgos o novedades"></textarea>
        </div>

        <div class="field">
          <label>Firma del responsable</label>
          <canvas id="signatureCanvas"></canvas>
          <div class="btn-row"><button class="btn btn-secondary" type="button" onclick="clearSignature()">Limpiar firma</button></div>
        </div>

        <div class="btn-row"><button class="btn" type="button" onclick="submitForm()">Guardar inspección</button></div>
        <div id="statusBox" class="status"></div>
      </section>
    </main>

    <script>
      const APP_DATA = <?!= JSON.stringify(data) ?>;
      let signatureCanvas, ctx, drawing = false;
      document.addEventListener('DOMContentLoaded', () => { setToday(); loadJoyeriaOptions(); loadAreas(); loadChecklist(); setupSignatureCanvas(); setupPhotoPreview(); applySelectedJoyeria(); });
      function setToday() { document.getElementById('fechaInspeccion').value = new Date().toISOString().split('T')[0]; }
      function loadJoyeriaOptions() {
        const joyeria = document.getElementById('joyeria');
        joyeria.innerHTML = '<option value="">Selecciona una joyería</option>' + APP_DATA.joyerias.map(j => `<option value="${escapeHtml(j.id)}">${escapeHtml(j.nombre)}</option>`).join('');
        joyeria.addEventListener('change', () => { syncJoyeriaEmail(); loadResponsables(); });
      }
      function applySelectedJoyeria() {
        if (APP_DATA.selectedJoyeriaId) {
          document.getElementById('joyeria').value = APP_DATA.selectedJoyeriaId;
          document.getElementById('joyeria').setAttribute('disabled', 'disabled');
          document.getElementById('joyeriaFija').classList.remove('hidden');
          document.getElementById('joyeriaFija').textContent = APP_DATA.selectedJoyeriaName;
        }
        syncJoyeriaEmail(); loadResponsables();
      }
      function syncJoyeriaEmail() { const id = document.getElementById('joyeria').value; const selected = APP_DATA.joyerias.find(j => j.id === id); document.getElementById('correo').value = selected ? selected.correo : ''; }
      function loadResponsables() {
        const id = document.getElementById('joyeria').value; const list = document.getElementById('responsablesList'); list.innerHTML = ''; if (!id) return;
        google.script.run.withSuccessHandler(names => { (names || []).forEach(n => { const o = document.createElement('option'); o.value = n; list.appendChild(o); }); }).getResponsablesByJoyeria(id);
      }
      function loadAreas() { document.getElementById('areasContainer').innerHTML = APP_DATA.areas.map(a => `<label class="chip"><input type="checkbox" name="areaItem" value="${escapeHtml(a)}"> ${escapeHtml(a)}</label>`).join(''); }
      function loadChecklist() {
        document.getElementById('checklistContainer').innerHTML = APP_DATA.checklist.map((item, index) => `<div class="checklist-item"><div><b>${index + 1}. ${escapeHtml(item)}</b></div><div style="margin-top:8px"><label class="chip"><input type="radio" name="check_${index}" value="Cumple"> Cumple</label><label class="chip"><input type="radio" name="check_${index}" value="No cumple"> No cumple</label><label class="chip"><input type="radio" name="check_${index}" value="No aplica"> No aplica</label></div></div>`).join('');
      }
      function setupPhotoPreview() { document.getElementById('photos').addEventListener('change', function() { const files = Array.from(this.files || []); document.getElementById('photoPreview').innerHTML = files.length ? `${files.length} archivo(s):<br>${files.map(f => '• ' + f.name).join('<br>')}` : ''; }); }
      function setupSignatureCanvas() {
        signatureCanvas = document.getElementById('signatureCanvas'); ctx = signatureCanvas.getContext('2d'); resizeCanvas(); window.addEventListener('resize', resizeCanvas);
        signatureCanvas.addEventListener('mousedown', startDraw); signatureCanvas.addEventListener('mousemove', draw); signatureCanvas.addEventListener('mouseup', stopDraw); signatureCanvas.addEventListener('mouseleave', stopDraw);
        signatureCanvas.addEventListener('touchstart', startDrawTouch, { passive: false }); signatureCanvas.addEventListener('touchmove', drawTouch, { passive: false }); signatureCanvas.addEventListener('touchend', stopDraw);
      }
      function resizeCanvas() { const ratio = window.devicePixelRatio || 1; const rect = signatureCanvas.getBoundingClientRect(); signatureCanvas.width = rect.width * ratio; signatureCanvas.height = 220 * ratio; ctx = signatureCanvas.getContext('2d'); ctx.scale(ratio, ratio); ctx.lineWidth = 2; ctx.lineCap = 'round'; ctx.strokeStyle = '#111111'; }
      function getCoords(e) { const rect = signatureCanvas.getBoundingClientRect(); return { x: e.clientX - rect.left, y: e.clientY - rect.top }; }
      function startDraw(e) { drawing = true; const pos = getCoords(e); ctx.beginPath(); ctx.moveTo(pos.x, pos.y); }
      function draw(e) { if (!drawing) return; const pos = getCoords(e); ctx.lineTo(pos.x, pos.y); ctx.stroke(); }
      function stopDraw() { drawing = false; } function startDrawTouch(e) { e.preventDefault(); startDraw(e.touches[0]); } function drawTouch(e) { e.preventDefault(); draw(e.touches[0]); }
      function clearSignature() { ctx.clearRect(0, 0, signatureCanvas.width, signatureCanvas.height); }
      function getSignatureBase64() { return signatureCanvas.toDataURL('image/png'); }
      function collectChecklist() { return APP_DATA.checklist.map((item, i) => { const selected = document.querySelector(`input[name="check_${i}"]:checked`); return { item, estado: selected ? selected.value : '' }; }); }
      function validateChecklist(checklist) { return checklist.every(item => item.estado); }
      function collectAreas() { return Array.from(document.querySelectorAll('input[name="areaItem"]:checked')).map(el => el.value); }
      function fileToBase64(file) { return new Promise((resolve, reject) => { const reader = new FileReader(); reader.onload = e => resolve({ fileName: file.name, mimeType: file.type, base64: e.target.result }); reader.onerror = reject; reader.readAsDataURL(file); }); }
      async function getPhotosBase64() { const files = Array.from(document.getElementById('photos').files || []); const results = []; for (const file of files) results.push(await fileToBase64(file)); return results; }
      async function submitForm() {
        const checklist = collectChecklist(); const areas = collectAreas();
        if (!validateChecklist(checklist)) return showStatus('Debes responder todos los puntos del checklist.', false);
        const payload = { fechaInspeccion: document.getElementById('fechaInspeccion').value, joyeriaId: document.getElementById('joyeria').value, responsable: document.getElementById('responsable').value.trim(), observaciones: document.getElementById('observaciones').value.trim(), checklist, areas, signatureBase64: getSignatureBase64(), registradoPor: document.getElementById('correo').value.trim() };
        if (!payload.fechaInspeccion || !payload.joyeriaId || !payload.responsable || !payload.areas.length) return showStatus('Completa todos los campos obligatorios y selecciona al menos un ÁREA.', false);
        try {
          showStatus('Guardando información...', true); payload.photos = await getPhotosBase64();
          google.script.run.withSuccessHandler(r => r.ok ? (showStatus(r.message, true), resetForm()) : showStatus(r.message, false)).withFailureHandler(e => showStatus(e.message || 'Ocurrió un error inesperado.', false)).saveInspection(payload);
        } catch (err) { showStatus('No fue posible procesar las imágenes.', false); }
      }
      function resetForm() { document.getElementById('responsable').value = ''; document.getElementById('observaciones').value = ''; document.getElementById('photos').value = ''; document.getElementById('photoPreview').innerHTML = ''; clearSignature(); setToday(); document.querySelectorAll('input[name="areaItem"]').forEach(i => i.checked = false); APP_DATA.checklist.forEach((_, i) => document.querySelectorAll(`input[name="check_${i}"]`).forEach(r => r.checked = false)); }
      function showStatus(message, success) { const box = document.getElementById('statusBox'); box.style.display = 'block'; box.className = 'status ' + (success ? 'success' : 'error'); box.textContent = message; }
      function escapeHtml(text) { return String(text).replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;').replace(/"/g, '&quot;').replace(/'/g, '&#039;'); }
    </script>
  </body>
</html>
